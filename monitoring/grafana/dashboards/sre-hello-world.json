{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "SRE Hello World — SLI/SLO dashboard: availability, latency, error rate, throughput, Redis",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "SLO Overview", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 99.5 },
              { "color": "green",  "value": 99.9 }
            ]
          },
          "unit": "percent",
          "mappings": [],
          "min": 99, "max": 100
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "expr": "(\n  1 - (\n    sum(rate(http_requests_total{status_code=~\"5..\",job=~\"$job\"}[$__rate_interval]))\n    / sum(rate(http_requests_total{job=~\"$job\"}[$__rate_interval]))\n  )\n) * 100",
        "legendFormat": "Availability",
        "refId": "A"
      }],
      "title": "Availability",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red",    "value": 0.5 }
            ]
          },
          "unit": "percent",
          "min": 0, "max": 5
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "orientation": "auto", "textMode": "auto", "justifyMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "expr": "(\n  sum(rate(http_requests_total{status_code=~\"5..\",job=~\"$job\"}[$__rate_interval]))\n  / sum(rate(http_requests_total{job=~\"$job\"}[$__rate_interval]))\n) * 100",
        "legendFormat": "Error Rate",
        "refId": "A"
      }],
      "title": "Error Rate",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red",    "value": 200 }
            ]
          },
          "unit": "ms",
          "min": 0, "max": 500
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "expr": "histogram_quantile(0.95,\n  sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le)\n) * 1000",
        "legendFormat": "P95",
        "refId": "A"
      }],
      "title": "P95 Latency (target ≤ 200 ms)",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 350 },
              { "color": "red",    "value": 500 }
            ]
          },
          "unit": "ms",
          "min": 0, "max": 1000
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "expr": "histogram_quantile(0.99,\n  sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le)\n) * 1000",
        "legendFormat": "P99",
        "refId": "A"
      }],
      "title": "P99 Latency (target ≤ 500 ms)",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green",  "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "expr": "(\n  1 - (\n    sum(rate(http_requests_total{status_code=~\"5..\",job=~\"$job\"}[30d]))\n    / sum(rate(http_requests_total{job=~\"$job\"}[30d]))\n  )\n) / 0.999 * 100",
        "legendFormat": "Budget Remaining",
        "refId": "A"
      }],
      "title": "Error Budget Remaining (30d)",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "orientation": "auto", "textMode": "auto", "justifyMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "expr": "sum(rate(http_requests_total{job=~\"$job\"}[$__rate_interval]))",
        "legendFormat": "RPS",
        "refId": "A"
      }],
      "title": "Throughput",
      "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101, "title": "Traffic & Errors", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(http_requests_total{job=~\"$job\",status_code=~\"2..\"}[$__rate_interval]))",
          "legendFormat": "2xx success", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(http_requests_total{job=~\"$job\",status_code=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx errors", "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(http_requests_total{job=~\"$job\",status_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx errors", "refId": "C"
        }
      ],
      "title": "Request Rate by Status",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95", "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99", "refId": "C"
        }
      ],
      "title": "Request Latency Percentiles",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102, "title": "Error Budget Burn", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-RdYlGr" },
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.014 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 9,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\",job=~\"$job\"}[1h]))\n/ sum(rate(http_requests_total{job=~\"$job\"}[1h]))",
          "legendFormat": "1h error ratio", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\",job=~\"$job\"}[6h]))\n/ sum(rate(http_requests_total{job=~\"$job\"}[6h]))",
          "legendFormat": "6h error ratio", "refId": "B"
        }
      ],
      "title": "Error Ratio (multi-window burn rate)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Fast burn (14.4×)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Slow burn (1×)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "SLO threshold" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "(\n  sum(rate(http_requests_total{status_code=~\"5..\",job=~\"$job\"}[1h]))\n  / sum(rate(http_requests_total{job=~\"$job\"}[1h]))\n) / 0.001",
          "legendFormat": "Fast burn (14.4×)", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "(\n  sum(rate(http_requests_total{status_code=~\"5..\",job=~\"$job\"}[6h]))\n  / sum(rate(http_requests_total{job=~\"$job\"}[6h]))\n) / 0.001",
          "legendFormat": "Slow burn (1×)", "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "vector(1)",
          "legendFormat": "SLO threshold", "refId": "C"
        }
      ],
      "title": "Burn Rate (multiples of SLO budget)",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103, "title": "Redis", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 24 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "orientation": "auto", "textMode": "auto", "justifyMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "expr": "redis_keys_total",
        "legendFormat": "Keys", "refId": "A"
      }],
      "title": "Redis Keys",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green",  "value": 95 }
            ]
          },
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 24 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "expr": "rate(redis_operations_total{operation=\"get\",status=\"hit\"}[$__rate_interval])\n/ rate(redis_operations_total{operation=\"get\"}[$__rate_interval]) * 100",
        "legendFormat": "Cache Hit Rate", "refId": "A"
      }],
      "title": "Redis Cache Hit Rate",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "ms", "min": 0, "max": 200
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 24 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "expr": "histogram_quantile(0.99,\n  sum(rate(redis_operation_duration_seconds_bucket[$__rate_interval])) by (le)\n) * 1000",
        "legendFormat": "P99 Redis Latency", "refId": "A"
      }],
      "title": "Redis P99 Latency",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 14,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(redis_operations_total[$__rate_interval])) by (operation)",
          "legendFormat": "{{ operation }}", "refId": "A"
        }
      ],
      "title": "Redis Operations / s by Type",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 28 },
      "id": 15,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(redis_operations_total[$__rate_interval])) by (status)",
          "legendFormat": "{{ status }}", "refId": "A"
        }
      ],
      "title": "Redis Operations by Status (errors in red)",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104, "title": "Application", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 16,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(http_requests_in_progress{job=~\"$job\"}) by (endpoint)",
          "legendFormat": "{{ endpoint }}", "refId": "A"
        }
      ],
      "title": "In-Flight Requests by Endpoint",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 17,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(http_requests_total{job=~\"$job\"}[$__rate_interval])) by (endpoint)",
          "legendFormat": "{{ endpoint }}", "refId": "A"
        }
      ],
      "title": "Request Rate by Endpoint",
      "type": "timeseries"
    }

  ],

  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["sre", "slo", "redis", "prometheus"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "definition": "label_values(http_requests_total, job)",
        "hide": 0,
        "includeAll": true,
        "label": "Job",
        "multi": false,
        "name": "job",
        "options": [],
        "query": { "query": "label_values(http_requests_total, job)", "refId": "A" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SRE Hello World — SLI/SLO",
  "uid": "sre-hello-world-slo",
  "version": 1
}
